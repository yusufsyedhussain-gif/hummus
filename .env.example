# Product Hub - Environment Variables

## Backend
DATABASE_URL=postgresql+asyncpg://producthub:producthub@localhost:5432/producthub
DATABASE_SYNC_URL=postgresql+psycopg2://producthub:producthub@localhost:5432/producthub
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=true
UPLOAD_DIR=/tmp/product-hub/uploads
MAX_UPLOAD_SIZE_MB=100
CSV_BATCH_SIZE=10000
WEBHOOK_TIMEOUT_SECONDS=10

## Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
